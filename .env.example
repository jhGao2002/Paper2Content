# Main LLM used by the modular app entrypoint (main.py)
LLM_MODEL_ID=glm-5
LLM_API_KEY=your_zhipu_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Fast model + embeddings used across retrieval/planning/evaluation
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_URL=https://open.bigmodel.cn/api/paas/v4/
EMBED_BATCH_SIZE=64

# Optional: dedicated image generation config for XHS note cover (DashScope / Aliyun)
DASHSCOPE_API_KEY=
DASHSCOPE_IMAGE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
DASHSCOPE_IMAGE_MODEL=z-image-turbo
DASHSCOPE_IMAGE_SIZE=512*512
DASHSCOPE_IMAGE_FINAL_SIZE=512*512
DASHSCOPE_IMAGE_PROMPT_EXTEND=0
# Optional fallback name used by some other projects
QWEN_IMAGE_API_KEY=
XHS_NOTE_IMAGE_OUTPUT_DIR=result/xhs_note_images

# Optional: local Xiaohongshu MCP publish endpoint
XHS_MCP_ENDPOINT=http://localhost:18060/mcp
STYLE_TRANSFER_MCP_ENDPOINT=http://127.0.0.1:1234/mcp

# FAISS storage
FAISS_INDEX_ROOT=vectorstores
FAISS_USE_GPU=0
FAISS_GPU_DEVICE=0

# Gradio
GRADIO_SHARE=0

# Optional: LangSmith tracing
LANGSMITH_TRACING=0
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=paper2content
LANGSMITH_WORKSPACE_ID=
LANGSMITH_APP_NAME=paper_assistant
LANGSMITH_TAGS=paper2content,local
LANGSMITH_METADATA={"source":"main.py","environment":"dev"}
